                    "type": "string"
                  },
                  "content": {
                    "type": "string"
                  },
                  "price": {
                    "type": "number",
                    "example": 15000000
                  },
                  "priceType": {
                    "type": "string",
                    "enum": [
                      "fixed",
                      "contact"
                    ],
                    "example": "fixed"
                  },
                  "thumbnail": {
                    "type": "string",
                    "example": "https://example.com/product.jpg"
                  },
                  "images": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    },
                    "example": [
