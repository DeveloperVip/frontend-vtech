  "paths": {
    "/auth/login": {
      "post": {
        "summary": "Đăng nhập admin",
        "tags": [
          "Auth"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "email",
                  "password"
                ],
                "properties": {
                  "email": {
                    "type": "string",
                    "example": "admin@gmail.com"
                  },
                  "password": {
                    "type": "string",
                    "example": 123456
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Login thành công"
          },
          "400": {
            "description": "Thiếu email hoặc password"
          }
        }
      }
    },
    "/auth/me": {
      "get": {
        "summary": "Lấy thông tin admin hiện tại",
