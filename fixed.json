                  },
                  "isActive": {
                    "type": "boolean",
                    "example": true
                  },
                  "sortOrder": {
                    "type": "integer",
                    "example": 1
                  },
                  "metaTitle": {
                    "type": "string"
                  },
                  "metaDescription": {
                    "type": "string"
                  }
                }
              }
            }
